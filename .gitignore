node_modules/
.next/
out/
dist/

# Generated by scripts/prebuild-static.mjs. Re-created on every
# build:static, so no need to track.
public/runs/
public/index.json
public/compare-pairs.json

# Stashes left by prebuild-static.mjs if a build is interrupted.
# Safe to `rm -rf` — restore original trees via `git checkout .`.
_stash_*

# Local run store. Each uploaded .ordo-run archive lives here as
# <.runs>/<run-id>/{archive.ordo-run, manifest.json, events.ndjson, ...}.
# Kept out of git so the repo stays clean; seeded demo runs can be
# regenerated via `pnpm seed:demo`.
.runs/

# Local family-events log emitted by the upload route.
evidence/

# Env / editor.
.env
.env.local
.env.*.local
.vscode/
.idea/
*.log
.DS_Store
